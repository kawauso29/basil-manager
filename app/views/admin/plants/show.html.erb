id: <%= @plant.id %><br>
name: <%= @plant.name %><br>
code: <%= @plant.code %><br>
prefix: <%= @plant.prefix %><br>
last_stock_number: <%= @plant.last_stock_number %><br>
作成日: <%= @plant.created_at %><br>
更新日: <%= @plant.updated_at %><br>

<%= link_to "編集", edit_admin_plant_path(@plant) %><br>
<%= link_to "一覧に戻る", admin_plants_path %><br>

<%= form_with model: [:admin, @plant], method: :delete do |f| %>
  <%= f.submit "削除", data: { confirm: "本当に削除しますか？" } %>
<% end %>