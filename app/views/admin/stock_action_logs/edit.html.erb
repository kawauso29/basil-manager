id: <%= @stock_action_log.id %><br>
stock_code: <%= @stock.code %><br>
location_name: <%= @location.name %>
plant_name: <%= @plant.name %><br>
<%= form_with model: [:admin, @stock_action_log] do |f| %>
  action_type: <%= f.select(:action_type, @action_type_data, {prompt: "選択してください"}) %><br><br>
  memo: <%= f.text_area :memo %><br>
  recorded_at: <%= f.datetime_local_field :recorded_at %><br>
  <%= f.submit "更新" %>
<% end %>