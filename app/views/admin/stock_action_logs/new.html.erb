<%= form_with model: [:admin, @stock_action_log] do |f| %>
  stock: <%= f.select(:stock_id,  @stock_data, {prompt: "選択してください"}) %><br>
  action_type: <%= f.select(:action_type, @action_type_data, {prompt: "選択してください"}) %><br>
  memo: <%= f.text_area :memo %><br>
  recorded_at: <%= f.datetime_local_field :recorded_at %><br>
  <%= f.submit "作成" %>
<% end %>