<%= form_with model: [:admin, @location_observation] do |f| %>
  location: <%= f.select(:location_id,  @location_data, {prompt: "選択してください"}) %><br>
  weather: <%= f.select(:weather,  @weather_data, {prompt: "選択してください"}) %><br>
  temperature: <%= f.number_field(:temperature) %><br>
  memo: <%= f.text_area :memo %><br>
  recorded_at: <%= f.datetime_local_field :recorded_at %><br>

  <%= f.submit "作成" %>
<% end %>